---
import { siteConfig } from "../config";
---

<footer class="bg-gray-900 text-white py-8 sm:py-12 md:py-16 lg:py-20 px-8 sm:px-12 md:px-16 lg:px-24">
  <div class="max-w-7xl mx-auto">
    <!-- Main footer content -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 pb-8 md:pb-12 border-b border-gray-700">
      <div class="space-y-4">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold">
          {siteConfig.name}
        </h2>
        <p class="text-lg sm:text-xl text-gray-400">
          {siteConfig.title}
        </p>
      </div>

      <div class="flex flex-col items-start md:items-end gap-4 md:gap-6">
        <div class="flex gap-4 sm:gap-6 md:gap-8">
          {
            siteConfig.social?.email && (
              <a
                href={`mailto:${siteConfig.social.email}`}
                aria-label="Email"
                class="group transition-all duration-300 hover:opacity-100 opacity-70"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8"
                >
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
                  <path d="M3 7l9 6l9 -6" />
                </svg>
              </a>
            )
          }
          {
            siteConfig.social?.linkedin && (
              <a
                href={siteConfig.social.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="LinkedIn"
                class="group transition-all duration-300 hover:opacity-100 opacity-70"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8"
                >
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <path d="M4 4m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z" />
                  <path d="M8 11l0 5" />
                  <path d="M8 8l0 .01" />
                  <path d="M12 16l0 -5" />
                  <path d="M16 16l0 -3a2 2 0 0 0 -4 0" />
                </svg>
              </a>
            )
          }
          {
            siteConfig.social?.github && (
              <a
                href={siteConfig.social.github}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GitHub"
                class="group transition-all duration-300 hover:opacity-100 opacity-70"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8"
                >
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
                </svg>
              </a>
            )
          }
          {
            siteConfig.social?.instagram && (
              <a
                href={siteConfig.social.instagram}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram"
                class="group transition-all duration-300 hover:opacity-100 opacity-70"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="w-6 h-6 sm:w-7 sm:h-7 md:w-8 md:h-8"
                >
                  <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                  <rect x="4" y="4" width="16" height="16" rx="4" />
                  <circle cx="12" cy="12" r="3" />
                  <line x1="16.5" y1="7.5" x2="16.5" y2="7.501" />
                </svg>
              </a>
            )
          }
        </div>

        <nav class="flex flex-col items-start md:items-end gap-2 text-sm sm:text-base text-gray-400 hover:text-white transition-colors">
          <a href="#about" class="hover:text-white transition-colors duration-300">
            About
          </a>
          <a href="#projects" class="hover:text-white transition-colors duration-300">
            Projects
          </a>
          <a href="#experience" class="hover:text-white transition-colors duration-300">
            Experience
          </a>
          <a href="#education" class="hover:text-white transition-colors duration-300">
            Education
          </a>
        </nav>
      </div>
    </div>

    <!-- Bottom footer -->
    <div class="pt-8 md:pt-12 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm sm:text-base text-gray-500">
        © {new Date().getFullYear()} {siteConfig.name}. All rights reserved.
      </p>
      <p class="text-sm sm:text-base text-gray-500">
        Made with ❤️ using <span style={{ color: siteConfig.accentColor }}>Astro</span> + <span style={{ color: siteConfig.accentColor }}>Tailwind CSS</span>
      </p>
    </div>
  </div>
</footer>
