---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
---

{
  hasExperience && (
    <section id="experience" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-black dark:text-white">
              Experience
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8">
            <div class="relative space-y-8">
              <!-- Timeline line -->
              <div class="hidden sm:block absolute left-4 md:left-6 lg:left-8 top-0 bottom-0 w-1 bg-gradient-to-b from-black/20 to-black/10 dark:from-white/20 dark:to-white/10" />

              {siteConfig.experience.map((exp, index) => (
                <div class="relative pl-16 md:pl-20 lg:pl-24">
                  <!-- Timeline dot -->
                  <div
                    class="hidden sm:block absolute left-0 md:left-1 lg:left-2 top-2 w-8 md:w-10 lg:w-12 h-8 md:h-10 lg:h-12 rounded-full border-4 border-white dark:border-[var(--bg-dark)] flex items-center justify-center"
                    style={`background-color: ${siteConfig.accentColor}, box-shadow: 0 0 0 4px ${siteConfig.accentColor}33`}
                  >
                    <div class="w-3 h-3 md:w-4 md:h-4 lg:w-5 lg:h-5 bg-white dark:bg-[var(--bg-dark)] rounded-full" />
                  </div>

                  <div class="space-y-2">
                    <h3 class="text-lg sm:text-xl md:text-2xl font-bold text-black dark:text-white">
                      {exp.company}
                    </h3>
                    <p
                      class="text-base sm:text-lg font-semibold"
                      style={{ color: siteConfig.accentColor }}
                    >
                      {exp.position}
                    </p>
                    {exp.period && (
                      <p class="text-sm sm:text-base text-black/50 dark:text-white/50 font-medium">
                        {exp.period}
                      </p>
                    )}
                    {exp.description && (
                      <p class="text-base sm:text-lg text-black/70 dark:text-white/70 leading-relaxed pt-2">
                        {exp.description}
                      </p>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
