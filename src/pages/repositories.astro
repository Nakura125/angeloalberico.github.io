const response = await fetch('https://api.github.com/users/Nakura125/repos?sort=updated');
const repos = await response.json();
---

<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Repositories - Angelo Alberico</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            line-height: 1.6;
            color: #333;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 2rem;
        }

        nav {
            max-width: 900px;
            margin: 0 auto 3rem;
            display: flex;
            justify-content: center;
            gap: 2rem;
            flex-wrap: wrap;
        }

        nav a {
            color: white;
            text-decoration: none;
            font-weight: 600;
            font-size: 1.1rem;
            padding: 0.5rem 1rem;
            border-radius: 4px;
            transition: background 0.3s;
        }

        nav a:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
            background: white;
            border-radius: 12px;
            padding: 3rem;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        }

        h1 {
            font-size: 2.5rem;
            margin-bottom: 2rem;
            color: #667eea;
            text-align: center;
        }

        .repos-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .repo-card {
            background: #f8f9fa;
            border: 1px solid #e0e0e0;
            border-left: 4px solid #667eea;
            border-radius: 8px;
            padding: 1.5rem;
            transition: transform 0.3s, box-shadow 0.3s;
            display: flex;
            flex-direction: column;
        }

        .repo-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(102, 126, 234, 0.2);
        }

        .repo-card h3 {
            font-size: 1.2rem;
            color: #667eea;
            margin-bottom: 0.5rem;
            margin-top: 0;
        }

        .repo-card a {
            color: #667eea;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s;
        }

        .repo-card a:hover {
            color: #764ba2;
        }

        .repo-description {
            font-size: 0.95rem;
            color: #555;
            margin: 0.75rem 0;
            flex-grow: 1;
            line-height: 1.6;
        }

        .repo-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            font-size: 0.85rem;
            color: #666;
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid #e0e0e0;
        }

        .repo-language {
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

        .repo-language-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
        }

        .repo-stats {
            display: flex;
            gap: 1rem;
            font-size: 0.85rem;
            color: #666;
        }

        .repo-stats span {
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

        .empty-message {
            text-align: center;
            color: #666;
            padding: 3rem 1rem;
        }
    </style>
</head>
<body>
    <nav>
        <a href="/">About</a>
        <a href="/projects">Projects</a>
        <a href="/repositories">Repositories</a>
        <a href="/cv">CV</a>
    </nav>

    <div class="container">
        <h1>I Miei Repository GitHub</h1>

        {repos && repos.length > 0 ? (
            <div class="repos-grid">
                {repos.map((repo) => (
                    <div class="repo-card">
                        <h3>
                            <a href={repo.html_url} target="_blank" rel="noopener noreferrer">
                                {repo.name}
                            </a>
                        </h3>
                        {repo.description && (
                            <p class="repo-description">{repo.description}</p>
                        )}
                        <div class="repo-meta">
                            {repo.language && (
                                <div class="repo-language">
                                    <span class="repo-language-dot" style={getLanguageColor(repo.language)}></span>
                                    {repo.language}
                                </div>
                            )}
                            {repo.stargazers_count > 0 && (
                                <div class="repo-stats">
                                    <span>⭐ {repo.stargazers_count}</span>
                                </div>
                            )}
                            {repo.forks_count > 0 && (
                                <div class="repo-stats">
                                    <span>🍴 {repo.forks_count}</span>
                                </div>
                            )}
                        </div>
                    </div>
                ))}
            </div>
        ) : (
            <div class="empty-message">
                <p>Nessun repository trovato</p>
            </div>
        )}
    </div>

    <script>
        function getLanguageColor(language) {
            const colors = {
                'JavaScript': '#f7df1e',
                'TypeScript': '#3178c6',
                'Python': '#3776ab',
                'Java': '#007396',
                'CSS': '#563d7c',
                'HTML': '#e34c26',
                'React': '#61dafb',
                'Vue': '#4fc08d',
                'Astro': '#ff5a03',
            };
            return `background-color: ${colors[language] || '#888888'}`;
        }
    </script>
</body>
</html>