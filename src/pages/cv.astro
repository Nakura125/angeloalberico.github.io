        </div>

        <!-- Languages -->
        <div class="cv-section">
            <div class="cv-section-title">Lingue</div>
            <div class="cv-entry">
                <p><strong>Italiano:</strong> Madrelingua</p>
                <p><strong>Inglese:</strong> Fluente (B2)</p>
            </div>
        </div>

        <button class="download-button" onclick="window.print()">📥 Scarica CV (PDF)</button>
    </div>
</body>
</html>
