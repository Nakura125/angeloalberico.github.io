---
import '../styles/global.css';

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<!-- Favicon variants for all browsers -->
	<link rel="icon" type="image/x-icon" href="/favicon.ico" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
	<!-- Apple specific -->
	<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
	<!-- Web App Manifest -->
	<link rel="manifest" href="/site.webmanifest" />
	<!-- Mobile and theme -->
	<meta name="apple-mobile-web-app-capable" content="yes" />
	<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
	<meta name="apple-mobile-web-app-title" content="Angelo" />
	<meta name="theme-color" content="#BD93F9" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<meta name="description" content="Angelo Alberico - Computer Science Student & Developer" />
	<title>{title}</title>
</head>
<body class="bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 transition-colors duration-300">
	<slot />
</body>
</html>

<style is:global>
	html {
		font-family: system-ui, -apple-system, sans-serif;
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		padding: 0;
	}

	@supports (animation-timeline: view()) {
		.scroll-reveal {
			animation: fadeInUp 0.6s ease-out forwards;
			animation-timeline: view();
		}
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>
